# Copy this file to ".env" and fill in your values.

# Set to "true" to run fully against the Firebase Emulator Suite (local dev,
# no real project needed). Set to "false" to use the real Firebase project below.
VITE_USE_EMULATORS=true

# Firebase web app config — find these in Firebase Console → Project settings
# → Your apps → SDK setup. Required when VITE_USE_EMULATORS=false.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# App Check (reCAPTCHA v3) site key. Required in production so the backend
# accepts requests. Register it in Firebase Console → App Check.
# Leave empty for local emulator development.
VITE_RECAPTCHA_SITE_KEY=

# Web Push (FCM) — Firebase Console → Project settings → Cloud Messaging
# → Web Push certificates → Generate key pair. Required for browser notifications.
VITE_FIREBASE_VAPID_KEY=
