# ==============================
# Dependencies
# ==============================
node_modules/

# ==============================
# Build output
# ==============================
dist/
dist-ssr/

# ==============================
# Environment & secrets (client)
# Never commit real keys, tokens, or production config.
# Keep .env.example as the template (placeholders only).
# ==============================
.env
.env.*
!.env.example

# Vite local overrides
*.local

# ==============================
# Firebase
# ==============================
.firebase/
# Generated at dev/build from VITE_* — commit .example only, not real config
public/firebase-sw-config.js
!public/firebase-sw-config.js.example
*-debug.log
firestore-debug.log
ui-debug.log
firebase-debug.log
pubsub-debug.log

